# =====================================================
# CV Pintar - Environment Variables Template
# =====================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in the values (see below)
# 3. NEVER commit .env to version control!
#
# ⚠️ SECURITY RULES:
# - VITE_ prefix = Client-side safe (can be in .env)
# - No prefix = Server-side ONLY (use .dev.vars for local, deployment secrets for production)
# =====================================================

# ─── Supabase Client-Side (VITE_ prefix - Safe) ──────────────────
# These are ANON/PUBLISHABLE keys - safe for browser exposure
# Get from: Supabase Dashboard → Project Settings → API → Project API keys
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_publishable_key_here"
VITE_SUPABASE_PROJECT_ID="your_project_id"

# ─── hCaptcha Client-Side (VITE_ prefix - Safe) ──────────────────
# Site key is public - used for client-side captcha rendering
# Get from: https://www.hcaptcha.com/
VITE_HCAPTCHA_SITE_KEY="your_hcaptcha_site_key"

# Benix CS Chatbot Widget Client-Side (VITE_ prefix - Safe)
# Widget token from Benix AI dashboard. This is loaded in the browser.
VITE_BENIX_CS_WIDGET_TOKEN="bkn_cs_widget_xxx"

# ─── Server-Side Variables ───────────────────────────────────────
# ⚠️ DO NOT ADD TO THIS FILE!
#
# For LOCAL DEVELOPMENT:
# Add to .dev.vars (gitignored automatically)
#
# For PRODUCTION (Vercel):
# Set in Vercel Dashboard → Project Settings → Environment Variables
#
# For PRODUCTION (Supabase Edge Functions):
# Set in Supabase Dashboard → Project Settings → Edge Functions → Secrets
#
# Variables needed:
# - SUPABASE_URL: Full Supabase URL
# - SUPABASE_PUBLISHABLE_KEY: Same as VITE_ version for server-side auth
# - SUPABASE_SERVICE_ROLE_KEY: Service role key (NEVER expose to client!)
# - AI_API_KEY: Your AI Gateway / OpenAI / Anthropic API key
# - AI_GATEWAY_URL: AI Gateway endpoint
# - RESEND_API_KEY: Email service API key
# - MIDTRANS_SERVER_KEY: Midtrans server-side key
# - MIDTRANS_CLIENT_KEY: Midtrans client-side key
# - HCAPTCHA_SECRET_KEY: hCaptcha server-side secret
