# CV Pintar - Environment Variables Template
# Copy this file to .env and fill in the values
# IMPORTANT: Never commit .env to version control!

# Supabase (safe to commit - publishable key only)
SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key_here"
SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key_here"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# ⚠️ SECURITY: These are server-side only variables
# For Supabase Edge Functions, set these in Supabase Dashboard → Settings → Edge Functions → Secrets
# For Vercel Deployment, set these in Vercel Dashboard → Project Settings → Environment Variables
# SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here" (server-only, never expose to client)
# AI_API_KEY="your_ai_gateway_api_key_here" (server-only, never expose to client)
# RESEND_API_KEY="your_resend_api_key_here" (server-only, never expose to client)
# MIDTRANS_SERVER_KEY="your_midtrans_server_key_here" (server-only, never expose to client)

# hCaptcha - Dapatkan di https://www.hcaptcha.com/
# Site key (public) - digunakan di client-side (VITE_ prefix agar tersedia di browser)
VITE_HCAPTCHA_SITE_KEY="your_hcaptcha_site_key"
# Secret key - JANGAN taruh di file .env! Gunakan Supabase Secrets:
#   supabase secrets set HCAPTCHA_SECRET_KEY="your_hcaptcha_secret_key"
